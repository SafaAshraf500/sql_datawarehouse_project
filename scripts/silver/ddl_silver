-- ============================================================
-- SILVER LAYER  –  Retail Data Warehouse (12 Tables)
-- Silver = clean copy of bronze + dwh_create_date
-- NO merging here  →  merging happens in GOLD layer
-- ============================================================

-- ─────────────────────────────────────────
-- 1. customers
-- ─────────────────────────────────────────
IF OBJECT_ID ('silver.customers', 'U') IS NOT NULL
    DROP TABLE silver.customers;

CREATE TABLE silver.customers (
    customer_id        INT,
    customer_city      NVARCHAR(50),
    signup_date        DATE,
    dwh_create_date    DATETIME2 DEFAULT GETDATE()
);

INSERT INTO silver.customers (customer_id, customer_city, signup_date)
SELECT
    customer_id,
    TRIM(city),
    signup_date
FROM bronze.customers
WHERE customer_id IS NOT NULL;

-- ─────────────────────────────────────────
-- 2. orders
-- ─────────────────────────────────────────
IF OBJECT_ID ('silver.orders', 'U') IS NOT NULL
    DROP TABLE silver.orders;

CREATE TABLE silver.orders (
    order_id           INT,
    customer_id        INT,
    store_id           INT,
    promotion_id       INT,
    order_date         DATE,
    dwh_create_date    DATETIME2 DEFAULT GETDATE()
);

INSERT INTO silver.orders (order_id, customer_id, store_id, promotion_id, order_date)
SELECT
    order_id,
    customer_id,
    store_id,
    promotion_id,
    order_date
FROM bronze.orders
WHERE order_id IS NOT NULL;

-- ─────────────────────────────────────────
-- 3. order_items
-- ─────────────────────────────────────────
IF OBJECT_ID ('silver.order_items', 'U') IS NOT NULL
