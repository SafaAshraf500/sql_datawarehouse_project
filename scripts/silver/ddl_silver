CREATE TABLE silver.order_items (
    order_item_id      INT,
    order_id           INT,
    product_id         INT,
    qty                INT,
    item_price         DECIMAL(10, 2),
    dwh_create_date    DATETIME2 DEFAULT GETDATE()
);

INSERT INTO silver.order_items (order_item_id, order_id, product_id, qty, item_price)
SELECT
    order_item_id,
    order_id,
    product_id,
    qty,
    price
FROM bronze.order_items
WHERE order_item_id IS NOT NULL;

