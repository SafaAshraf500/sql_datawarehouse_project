-- ─────────────────────────────────────────
-- 9. promotions
-- ─────────────────────────────────────────
IF OBJECT_ID ('silver.promotions', 'U') IS NOT NULL
    DROP TABLE silver.promotions;

CREATE TABLE silver.promotions (
    promotion_id       INT,
    discount           INT,
    dwh_create_date    DATETIME2 DEFAULT GETDATE()
);

INSERT INTO silver.promotions (promotion_id, discount)
SELECT DISTINCT 
    promotion_id,
    discount
FROM bronze.promotions
WHERE promotion_id IS NOT NULL;

SELECT promotion_id, COUNT(*)
FROM bronze.promotions
GROUP BY promotion_id
HAVING COUNT(*) > 1;
